generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum WarehouseType {
  STORE
  STOCKROOM
  DISTRIBUTION_CENTER
  TRANSIT
  DAMAGE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum PosShiftStatus {
  OPEN
  CLOSED
  VOIDED
}

enum SaleStatus {
  DRAFT
  COMPLETED
  VOIDED
  REFUNDED
}

enum PaymentMethodType {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_WALLET
  STORE_CREDIT
  GIFT_CARD
}

enum PurchaseReceiptStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum InventoryMovementType {
  OPENING_BALANCE
  PURCHASE_IN
  SALE_OUT
  SALE_RETURN_IN
  PURCHASE_RETURN_OUT
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_GAIN
  ADJUSTMENT_LOSS
  MANUAL_IN
  MANUAL_OUT
}

enum InventorySourceType {
  SALE
  PURCHASE
  TRANSFER
  ADJUSTMENT
  OPENING_BALANCE
  MANUAL
}

enum StockTransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum StockAdjustmentReason {
  DAMAGE
  EXPIRY
  SHRINKAGE
  COUNT_VARIANCE
  OPENING_BALANCE
  MANUAL_CORRECTION
}

enum StockAdjustmentStatus {
  DRAFT
  APPROVED
  CANCELLED
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST_OF_SALES
  EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum BalanceSide {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

enum JournalSourceType {
  SALE
  PURCHASE
  TRANSFER
  ADJUSTMENT
  OPENING_BALANCE
  MANUAL
  POS_SHIFT
}

enum DocumentType {
  SALE
  PURCHASE_RECEIPT
  STOCK_TRANSFER
  STOCK_ADJUSTMENT
  JOURNAL_ENTRY
  POS_SHIFT
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model Organization {
  id                String             @id @default(cuid())
  code              String             @unique @db.VarChar(30)
  name              String             @db.VarChar(200)
  baseCurrencyCode  String             @db.VarChar(3)
  timeZone          String             @db.VarChar(100)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  branches          Branch[]
  users             User[]
  roles             Role[]
  taxCodes          TaxCode[]
  productCategories ProductCategory[]
  products          Product[]
  priceLists        PriceList[]
  customers         Customer[]
  suppliers         Supplier[]
  paymentMethods    PaymentMethod[]
  accounts          Account[]
  fiscalPeriods     FiscalPeriod[]
  journalEntries    JournalEntry[]
  documentSequences DocumentSequence[]
  purchaseReceipts  PurchaseReceipt[]
  sales             Sale[]
}

model Branch {
  id                  String               @id @default(cuid())
  organizationId      String
  code                String               @db.VarChar(30)
  name                String               @db.VarChar(200)
  status              BranchStatus         @default(ACTIVE)
  phone               String?              @db.VarChar(30)
  email               String?              @db.VarChar(200)
  addressLine1        String?              @db.VarChar(200)
  addressLine2        String?              @db.VarChar(200)
  city                String?              @db.VarChar(120)
  country             String?              @db.VarChar(120)
  isHeadOffice        Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id])
  userRoleAssignments UserRoleAssignment[]
  warehouses          Warehouse[]
  posRegisters        PosRegister[]
  posShifts           PosShift[]
  sales               Sale[]
  purchaseReceipts    PurchaseReceipt[]
  stockTransfersFrom  StockTransfer[]      @relation("TransferFromBranch")
  stockTransfersTo    StockTransfer[]      @relation("TransferToBranch")
  stockAdjustments    StockAdjustment[]
  journalLines        JournalLine[]
  inventoryMovements  InventoryMovement[]
  documentSequences   DocumentSequence[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

model Warehouse {
  id                 String             @id @default(cuid())
  branchId           String
  code               String             @db.VarChar(30)
  name               String             @db.VarChar(200)
  type               WarehouseType      @default(STOCKROOM)
  allowNegativeStock Boolean            @default(false)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  branch             Branch             @relation(fields: [branchId], references: [id])
  posRegisters       PosRegister[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  purchaseReceipts   PurchaseReceipt[]
  stockAdjustments   StockAdjustment[]
  stockTransfersFrom StockTransfer[]    @relation("TransferFromWarehouse")
  stockTransfersTo   StockTransfer[]    @relation("TransferToWarehouse")

  @@unique([branchId, code])
  @@index([branchId, isActive])
}
model User {
  id                        String              @id @default(cuid())
  organizationId            String
  fullName                  String              @db.VarChar(200)
  email                     String?             @unique @db.VarChar(200)
  phone                     String?             @db.VarChar(30)
  passwordHash              String              @db.VarChar(255)
  pinHash                   String?             @db.VarChar(255)
  status                    UserStatus          @default(ACTIVE)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  organization              Organization        @relation(fields: [organizationId], references: [id])
  userRoleAssignments       UserRoleAssignment[]
  openedShifts              PosShift[]          @relation("ShiftOpenedBy")
  closedShifts              PosShift[]          @relation("ShiftClosedBy")
  salesAsCashier            Sale[]              @relation("SaleCashier")
  voidedSales               Sale[]              @relation("SaleVoidedBy")
  purchaseReceiptsCreated   PurchaseReceipt[]   @relation("PurchaseReceiptCreatedBy")
  purchaseReceiptsApproved  PurchaseReceipt[]   @relation("PurchaseReceiptApprovedBy")
  stockTransfersRequested   StockTransfer[]     @relation("TransferRequestedBy")
  stockTransfersApproved    StockTransfer[]     @relation("TransferApprovedBy")
  stockTransfersReceived    StockTransfer[]     @relation("TransferReceivedBy")
  stockAdjustmentsCreated   StockAdjustment[]   @relation("AdjustmentCreatedBy")
  stockAdjustmentsApproved  StockAdjustment[]   @relation("AdjustmentApprovedBy")
  inventoryMovementsCreated InventoryMovement[] @relation("InventoryMovementCreatedBy")
  journalEntriesPosted      JournalEntry[]      @relation("JournalPostedBy")

  @@index([organizationId, status])
}

model Role {
  id                  String               @id @default(cuid())
  organizationId      String
  code                String               @db.VarChar(50)
  name                String               @db.VarChar(120)
  description         String?              @db.VarChar(500)
  isSystem            Boolean              @default(false)
  permissions         Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id])
  userRoleAssignments UserRoleAssignment[]

  @@unique([organizationId, code])
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  branchId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  branch    Branch?  @relation(fields: [branchId], references: [id])

  @@unique([userId, roleId, branchId])
  @@index([branchId])
}

model TaxCode {
  id                   String                @id @default(cuid())
  organizationId       String
  code                 String                @db.VarChar(30)
  name                 String                @db.VarChar(120)
  rate                 Decimal               @default(0) @db.Decimal(9, 6)
  isInclusive          Boolean               @default(false)
  salesTaxAccountId    String?
  purchaseTaxAccountId String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id])
  salesTaxAccount      Account?              @relation("SalesTaxAccount", fields: [salesTaxAccountId], references: [id])
  purchaseTaxAccount   Account?              @relation("PurchaseTaxAccount", fields: [purchaseTaxAccountId], references: [id])
  defaultCategories    ProductCategory[]     @relation("CategoryDefaultTaxCode")
  defaultProducts      Product[]             @relation("ProductDefaultTaxCode")
  saleLines            SaleLine[]            @relation("SaleLineTaxCode")
  purchaseReceiptLines PurchaseReceiptLine[] @relation("PurchaseReceiptLineTaxCode")

  @@unique([organizationId, code])
}

model ProductCategory {
  id                String                     @id @default(cuid())
  organizationId    String
  parentId          String?
  code              String                     @db.VarChar(30)
  name              String                     @db.VarChar(120)
  defaultTaxCodeId  String?
  isActive          Boolean                    @default(true)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  organization      Organization               @relation(fields: [organizationId], references: [id])
  parent            ProductCategory?           @relation("ProductCategoryHierarchy", fields: [parentId], references: [id])
  children          ProductCategory[]          @relation("ProductCategoryHierarchy")
  defaultTaxCode    TaxCode?                   @relation("CategoryDefaultTaxCode", fields: [defaultTaxCodeId], references: [id])
  products          Product[]
  accountingProfile CategoryAccountingProfile?

  @@unique([organizationId, code])
  @@index([parentId])
}
model Product {
  id                   String                   @id @default(cuid())
  organizationId       String
  categoryId           String?
  defaultTaxCodeId     String?
  sku                  String                   @db.VarChar(60)
  name                 String                   @db.VarChar(200)
  description          String?                  @db.VarChar(1000)
  baseUom              String                   @db.VarChar(20)
  status               ProductStatus            @default(ACTIVE)
  trackInventory       Boolean                  @default(true)
  isService            Boolean                  @default(false)
  allowNegativeStock   Boolean                  @default(false)
  defaultCost          Decimal                  @default(0) @db.Decimal(18, 6)
  standardPrice        Decimal                  @default(0) @db.Decimal(18, 6)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  organization         Organization             @relation(fields: [organizationId], references: [id])
  category             ProductCategory?         @relation(fields: [categoryId], references: [id])
  defaultTaxCode       TaxCode?                 @relation("ProductDefaultTaxCode", fields: [defaultTaxCodeId], references: [id])
  barcodes             ProductBarcode[]
  priceListItems       PriceListItem[]
  inventoryBalances    InventoryBalance[]
  inventoryMovements   InventoryMovement[]
  saleLines            SaleLine[]
  purchaseReceiptLines PurchaseReceiptLine[]
  stockTransferLines   StockTransferLine[]
  stockAdjustmentLines StockAdjustmentLine[]
  accountingProfile    ProductAccountingProfile?

  @@unique([organizationId, sku])
  @@index([categoryId, status])
}

model ProductBarcode {
  id         String   @id @default(cuid())
  productId  String
  barcode    String   @unique @db.VarChar(100)
  unitFactor Decimal  @default(1) @db.Decimal(18, 4)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model PriceList {
  id             String       @id @default(cuid())
  organizationId String
  code           String       @db.VarChar(30)
  name           String       @db.VarChar(120)
  isDefault      Boolean      @default(false)
  validFrom      DateTime?    @db.Date
  validTo        DateTime?    @db.Date
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  items          PriceListItem[]
  sales          Sale[]

  @@unique([organizationId, code])
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  productId   String
  minQty      Decimal   @default(1) @db.Decimal(18, 4)
  unitPrice   Decimal   @default(0) @db.Decimal(18, 6)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  priceList   PriceList @relation(fields: [priceListId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId, minQty])
}

model Customer {
  id                  String       @id @default(cuid())
  organizationId      String
  receivableAccountId String?
  code                String       @db.VarChar(30)
  name                String       @db.VarChar(200)
  phone               String?      @db.VarChar(30)
  email               String?      @db.VarChar(200)
  taxNumber           String?      @db.VarChar(60)
  addressLine1        String?      @db.VarChar(200)
  addressLine2        String?      @db.VarChar(200)
  city                String?      @db.VarChar(120)
  country             String?      @db.VarChar(120)
  creditLimit         Decimal      @default(0) @db.Decimal(18, 4)
  openingBalance      Decimal      @default(0) @db.Decimal(18, 4)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id])
  receivableAccount   Account?     @relation("CustomerReceivableAccount", fields: [receivableAccountId], references: [id])
  sales               Sale[]

  @@unique([organizationId, code])
}

model Supplier {
  id               String            @id @default(cuid())
  organizationId   String
  payableAccountId String?
  code             String            @db.VarChar(30)
  name             String            @db.VarChar(200)
  phone            String?           @db.VarChar(30)
  email            String?           @db.VarChar(200)
  taxNumber        String?           @db.VarChar(60)
  addressLine1     String?           @db.VarChar(200)
  addressLine2     String?           @db.VarChar(200)
  city             String?           @db.VarChar(120)
  country          String?           @db.VarChar(120)
  openingBalance   Decimal           @default(0) @db.Decimal(18, 4)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id])
  payableAccount   Account?          @relation("SupplierPayableAccount", fields: [payableAccountId], references: [id])
  purchaseReceipts PurchaseReceipt[]

  @@unique([organizationId, code])
}

model PaymentMethod {
  id             String            @id @default(cuid())
  organizationId String
  accountId      String
  code           String            @db.VarChar(30)
  name           String            @db.VarChar(120)
  type           PaymentMethodType
  allowChange    Boolean           @default(false)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id])
  account        Account           @relation("PaymentMethodAccount", fields: [accountId], references: [id])
  salePayments   SalePayment[]

  @@unique([organizationId, code])
}

model PosRegister {
  id          String     @id @default(cuid())
  branchId    String
  warehouseId String
  code        String     @db.VarChar(30)
  name        String     @db.VarChar(120)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  branch      Branch     @relation(fields: [branchId], references: [id])
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  shifts      PosShift[]
  sales       Sale[]

  @@unique([branchId, code])
  @@index([warehouseId])
}
model PosShift {
  id                  String         @id @default(cuid())
  branchId            String
  registerId          String
  openedByUserId      String
  closedByUserId      String?
  shiftNumber         String         @db.VarChar(30)
  status              PosShiftStatus @default(OPEN)
  openedAt            DateTime       @default(now())
  closedAt            DateTime?
  openingFloat        Decimal        @default(0) @db.Decimal(18, 4)
  closingCashExpected Decimal        @default(0) @db.Decimal(18, 4)
  closingCashActual   Decimal        @default(0) @db.Decimal(18, 4)
  varianceAmount      Decimal        @default(0) @db.Decimal(18, 4)
  notes               String?        @db.VarChar(1000)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  branch              Branch         @relation(fields: [branchId], references: [id])
  register            PosRegister    @relation(fields: [registerId], references: [id])
  openedByUser        User           @relation("ShiftOpenedBy", fields: [openedByUserId], references: [id])
  closedByUser        User?          @relation("ShiftClosedBy", fields: [closedByUserId], references: [id])
  sales               Sale[]

  @@unique([branchId, shiftNumber])
  @@index([registerId, status])
}

model Sale {
  id             String       @id @default(cuid())
  organizationId String
  branchId       String
  registerId     String
  posShiftId     String
  cashierUserId  String
  customerId     String?
  priceListId    String?
  voidedByUserId String?
  saleNumber     String       @db.VarChar(30)
  saleDate       DateTime     @default(now())
  status         SaleStatus   @default(COMPLETED)
  subtotal       Decimal      @default(0) @db.Decimal(18, 4)
  discountTotal  Decimal      @default(0) @db.Decimal(18, 4)
  taxTotal       Decimal      @default(0) @db.Decimal(18, 4)
  totalAmount    Decimal      @default(0) @db.Decimal(18, 4)
  paidAmount     Decimal      @default(0) @db.Decimal(18, 4)
  changeAmount   Decimal      @default(0) @db.Decimal(18, 4)
  roundingAmount Decimal      @default(0) @db.Decimal(18, 4)
  costTotal      Decimal      @default(0) @db.Decimal(18, 4)
  notes          String?      @db.VarChar(1000)
  voidedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  branch         Branch       @relation(fields: [branchId], references: [id])
  register       PosRegister  @relation(fields: [registerId], references: [id])
  /// A sale must always belong to a POS shift. Enforce OPEN shift validation in the service layer before posting.
  posShift       PosShift     @relation(fields: [posShiftId], references: [id])
  cashierUser    User         @relation("SaleCashier", fields: [cashierUserId], references: [id])
  customer       Customer?    @relation(fields: [customerId], references: [id])
  priceList      PriceList?   @relation(fields: [priceListId], references: [id])
  voidedByUser   User?        @relation("SaleVoidedBy", fields: [voidedByUserId], references: [id])
  lines          SaleLine[]
  payments       SalePayment[]

  @@unique([branchId, saleNumber])
  @@index([posShiftId, status])
  @@index([branchId, saleDate])
}

model SaleLine {
  id             String    @id @default(cuid())
  saleId         String
  productId      String
  taxCodeId      String?
  lineNumber     Int
  quantity       Decimal   @default(0) @db.Decimal(18, 4)
  unitPrice      Decimal   @default(0) @db.Decimal(18, 6)
  discountAmount Decimal   @default(0) @db.Decimal(18, 4)
  taxAmount      Decimal   @default(0) @db.Decimal(18, 4)
  lineSubtotal   Decimal   @default(0) @db.Decimal(18, 4)
  lineTotal      Decimal   @default(0) @db.Decimal(18, 4)
  unitCost       Decimal   @default(0) @db.Decimal(18, 6)
  costTotal      Decimal   @default(0) @db.Decimal(18, 4)
  notes          String?   @db.VarChar(500)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sale           Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id])
  taxCode        TaxCode?  @relation("SaleLineTaxCode", fields: [taxCodeId], references: [id])

  @@unique([saleId, lineNumber])
  @@index([productId])
}

model SalePayment {
  id              String        @id @default(cuid())
  saleId          String
  paymentMethodId String
  amount          Decimal       @default(0) @db.Decimal(18, 4)
  referenceNumber String?       @db.VarChar(100)
  receivedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([paymentMethodId])
}

model PurchaseReceipt {
  id                    String                @id @default(cuid())
  organizationId        String
  branchId              String
  warehouseId           String
  supplierId            String
  createdByUserId       String
  approvedByUserId      String?
  receiptNumber         String                @db.VarChar(30)
  supplierInvoiceNumber String?               @db.VarChar(100)
  receiptDate           DateTime              @default(now())
  status                PurchaseReceiptStatus @default(RECEIVED)
  subtotal              Decimal               @default(0) @db.Decimal(18, 4)
  discountTotal         Decimal               @default(0) @db.Decimal(18, 4)
  taxTotal              Decimal               @default(0) @db.Decimal(18, 4)
  totalAmount           Decimal               @default(0) @db.Decimal(18, 4)
  notes                 String?               @db.VarChar(1000)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  organization          Organization          @relation(fields: [organizationId], references: [id])
  branch                Branch                @relation(fields: [branchId], references: [id])
  warehouse             Warehouse             @relation(fields: [warehouseId], references: [id])
  supplier              Supplier              @relation(fields: [supplierId], references: [id])
  createdByUser         User                  @relation("PurchaseReceiptCreatedBy", fields: [createdByUserId], references: [id])
  approvedByUser        User?                 @relation("PurchaseReceiptApprovedBy", fields: [approvedByUserId], references: [id])
  lines                 PurchaseReceiptLine[]

  @@unique([branchId, receiptNumber])
  @@index([branchId, receiptDate])
}

model PurchaseReceiptLine {
  id                String          @id @default(cuid())
  purchaseReceiptId String
  productId         String
  taxCodeId         String?
  lineNumber        Int
  quantity          Decimal         @default(0) @db.Decimal(18, 4)
  unitCost          Decimal         @default(0) @db.Decimal(18, 6)
  discountAmount    Decimal         @default(0) @db.Decimal(18, 4)
  taxAmount         Decimal         @default(0) @db.Decimal(18, 4)
  lineTotal         Decimal         @default(0) @db.Decimal(18, 4)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  purchaseReceipt   PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id])
  taxCode           TaxCode?        @relation("PurchaseReceiptLineTaxCode", fields: [taxCodeId], references: [id])

  @@unique([purchaseReceiptId, lineNumber])
  @@index([productId])
}
model InventoryBalance {
  id             String     @id @default(cuid())
  warehouseId    String
  productId      String
  qtyOnHand      Decimal    @default(0) @db.Decimal(18, 4)
  qtyReserved    Decimal    @default(0) @db.Decimal(18, 4)
  avgCost        Decimal    @default(0) @db.Decimal(18, 6)
  stockValue     Decimal    @default(0) @db.Decimal(18, 4)
  lastMovementAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  warehouse      Warehouse  @relation(fields: [warehouseId], references: [id])
  product        Product    @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([productId])
}

model InventoryMovement {
  id                String                @id @default(cuid())
  branchId          String
  warehouseId       String
  productId         String
  createdByUserId   String?
  movementDate      DateTime              @default(now())
  movementType      InventoryMovementType
  /// Store the originating document identity for audit. Example: sourceType=SALE and sourceId=<saleLineId or saleId by team convention>.
  sourceType        InventorySourceType
  sourceId          String                @db.VarChar(50)
  referenceNumber   String?               @db.VarChar(100)
  quantityDelta     Decimal               @default(0) @db.Decimal(18, 4)
  unitCost          Decimal               @default(0) @db.Decimal(18, 6)
  totalCost         Decimal               @default(0) @db.Decimal(18, 4)
  balanceAfterQty   Decimal               @default(0) @db.Decimal(18, 4)
  balanceAfterValue Decimal               @default(0) @db.Decimal(18, 4)
  notes             String?               @db.VarChar(500)
  createdAt         DateTime              @default(now())
  branch            Branch                @relation(fields: [branchId], references: [id])
  warehouse         Warehouse             @relation(fields: [warehouseId], references: [id])
  product           Product               @relation(fields: [productId], references: [id])
  createdByUser     User?                 @relation("InventoryMovementCreatedBy", fields: [createdByUserId], references: [id])

  @@index([warehouseId, productId, movementDate])
  @@index([sourceType, sourceId])
  @@index([branchId, movementDate])
}

model StockTransfer {
  id                String              @id @default(cuid())
  fromBranchId      String
  fromWarehouseId   String
  toBranchId        String
  toWarehouseId     String
  requestedByUserId String
  approvedByUserId  String?
  receivedByUserId  String?
  transferNumber    String              @db.VarChar(30)
  transferDate      DateTime            @default(now())
  shippedAt         DateTime?
  receivedAt        DateTime?
  status            StockTransferStatus @default(DRAFT)
  totalCost         Decimal             @default(0) @db.Decimal(18, 4)
  notes             String?             @db.VarChar(1000)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  fromBranch        Branch              @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  fromWarehouse     Warehouse           @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toBranch          Branch              @relation("TransferToBranch", fields: [toBranchId], references: [id])
  toWarehouse       Warehouse           @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  requestedByUser   User                @relation("TransferRequestedBy", fields: [requestedByUserId], references: [id])
  approvedByUser    User?               @relation("TransferApprovedBy", fields: [approvedByUserId], references: [id])
  receivedByUser    User?               @relation("TransferReceivedBy", fields: [receivedByUserId], references: [id])
  lines             StockTransferLine[]

  @@unique([fromBranchId, transferNumber])
  @@index([status, transferDate])
}

model StockTransferLine {
  id                String        @id @default(cuid())
  stockTransferId   String
  productId         String
  lineNumber        Int
  quantityRequested Decimal       @default(0) @db.Decimal(18, 4)
  quantitySent      Decimal       @default(0) @db.Decimal(18, 4)
  quantityReceived  Decimal       @default(0) @db.Decimal(18, 4)
  unitCost          Decimal       @default(0) @db.Decimal(18, 6)
  totalCost         Decimal       @default(0) @db.Decimal(18, 4)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  stockTransfer     StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product           Product       @relation(fields: [productId], references: [id])

  @@unique([stockTransferId, lineNumber])
  @@index([productId])
}

model StockAdjustment {
  id               String                @id @default(cuid())
  branchId         String
  warehouseId      String
  createdByUserId  String
  approvedByUserId String?
  adjustmentNumber String                @db.VarChar(30)
  adjustmentDate   DateTime              @default(now())
  reason           StockAdjustmentReason
  status           StockAdjustmentStatus @default(DRAFT)
  totalValueImpact Decimal               @default(0) @db.Decimal(18, 4)
  notes            String?               @db.VarChar(1000)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  branch           Branch                @relation(fields: [branchId], references: [id])
  warehouse        Warehouse             @relation(fields: [warehouseId], references: [id])
  createdByUser    User                  @relation("AdjustmentCreatedBy", fields: [createdByUserId], references: [id])
  approvedByUser   User?                 @relation("AdjustmentApprovedBy", fields: [approvedByUserId], references: [id])
  lines            StockAdjustmentLine[]

  @@unique([branchId, adjustmentNumber])
  @@index([branchId, adjustmentDate])
}

model StockAdjustmentLine {
  id                String          @id @default(cuid())
  stockAdjustmentId String
  productId         String
  lineNumber        Int
  systemQty         Decimal         @default(0) @db.Decimal(18, 4)
  countedQty        Decimal         @default(0) @db.Decimal(18, 4)
  differenceQty     Decimal         @default(0) @db.Decimal(18, 4)
  unitCost          Decimal         @default(0) @db.Decimal(18, 6)
  totalValueImpact  Decimal         @default(0) @db.Decimal(18, 4)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  stockAdjustment   StockAdjustment @relation(fields: [stockAdjustmentId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id])

  @@unique([stockAdjustmentId, lineNumber])
  @@index([productId])
}
model Account {
  id                        String                      @id @default(cuid())
  organizationId            String
  parentId                  String?
  code                      String                      @db.VarChar(30)
  name                      String                      @db.VarChar(200)
  type                      AccountType
  normalBalance             BalanceSide
  isPosting                 Boolean                     @default(true)
  allowManualEntries        Boolean                     @default(true)
  isActive                  Boolean                     @default(true)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  organization              Organization                @relation(fields: [organizationId], references: [id])
  parent                    Account?                    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                  Account[]                   @relation("AccountHierarchy")
  journalLines              JournalLine[]
  paymentMethods            PaymentMethod[]             @relation("PaymentMethodAccount")
  salesTaxCodes             TaxCode[]                   @relation("SalesTaxAccount")
  purchaseTaxCodes          TaxCode[]                   @relation("PurchaseTaxAccount")
  customerDefaults          Customer[]                  @relation("CustomerReceivableAccount")
  supplierDefaults          Supplier[]                  @relation("SupplierPayableAccount")
  categoryInventoryProfiles CategoryAccountingProfile[] @relation("CategoryInventoryAccount")
  categorySalesProfiles     CategoryAccountingProfile[] @relation("CategorySalesAccount")
  categoryCogsProfiles      CategoryAccountingProfile[] @relation("CategoryCogsAccount")
  categoryStockGainProfiles CategoryAccountingProfile[] @relation("CategoryStockGainAccount")
  categoryStockLossProfiles CategoryAccountingProfile[] @relation("CategoryStockLossAccount")
  productInventoryProfiles  ProductAccountingProfile[]  @relation("ProductInventoryAccount")
  productSalesProfiles      ProductAccountingProfile[]  @relation("ProductSalesAccount")
  productCogsProfiles       ProductAccountingProfile[]  @relation("ProductCogsAccount")
  productStockGainProfiles  ProductAccountingProfile[]  @relation("ProductStockGainAccount")
  productStockLossProfiles  ProductAccountingProfile[]  @relation("ProductStockLossAccount")

  @@unique([organizationId, code])
  @@index([parentId])
}

model CategoryAccountingProfile {
  id                 String          @id @default(cuid())
  categoryId         String          @unique
  inventoryAccountId String
  salesAccountId     String
  cogsAccountId      String
  stockGainAccountId String
  stockLossAccountId String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  category           ProductCategory @relation(fields: [categoryId], references: [id])
  inventoryAccount   Account         @relation("CategoryInventoryAccount", fields: [inventoryAccountId], references: [id])
  salesAccount       Account         @relation("CategorySalesAccount", fields: [salesAccountId], references: [id])
  cogsAccount        Account         @relation("CategoryCogsAccount", fields: [cogsAccountId], references: [id])
  stockGainAccount   Account         @relation("CategoryStockGainAccount", fields: [stockGainAccountId], references: [id])
  stockLossAccount   Account         @relation("CategoryStockLossAccount", fields: [stockLossAccountId], references: [id])
}

model ProductAccountingProfile {
  id                 String    @id @default(cuid())
  productId          String    @unique
  inventoryAccountId String
  salesAccountId     String
  cogsAccountId      String
  stockGainAccountId String
  stockLossAccountId String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  product            Product   @relation(fields: [productId], references: [id])
  inventoryAccount   Account   @relation("ProductInventoryAccount", fields: [inventoryAccountId], references: [id])
  salesAccount       Account   @relation("ProductSalesAccount", fields: [salesAccountId], references: [id])
  cogsAccount        Account   @relation("ProductCogsAccount", fields: [cogsAccountId], references: [id])
  stockGainAccount   Account   @relation("ProductStockGainAccount", fields: [stockGainAccountId], references: [id])
  stockLossAccount   Account   @relation("ProductStockLossAccount", fields: [stockLossAccountId], references: [id])
}

model FiscalPeriod {
  id                 String             @id @default(cuid())
  organizationId     String
  code               String             @db.VarChar(20)
  name               String             @db.VarChar(120)
  startDate          DateTime           @db.Date
  endDate            DateTime           @db.Date
  status             FiscalPeriodStatus @default(OPEN)
  isAdjustmentPeriod Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id])
  journalEntries     JournalEntry[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

model JournalEntry {
  id             String             @id @default(cuid())
  organizationId String
  fiscalPeriodId String
  postedByUserId String?
  entryNumber    String             @db.VarChar(30)
  entryDate      DateTime           @default(now())
  status         JournalEntryStatus @default(POSTED)
  sourceType     JournalSourceType
  sourceId       String             @db.VarChar(50)
  memo           String?            @db.VarChar(500)
  totalDebit     Decimal            @default(0) @db.Decimal(18, 4)
  totalCredit    Decimal            @default(0) @db.Decimal(18, 4)
  postedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  fiscalPeriod   FiscalPeriod       @relation(fields: [fiscalPeriodId], references: [id])
  postedByUser   User?              @relation("JournalPostedBy", fields: [postedByUserId], references: [id])
  lines          JournalLine[]

  @@unique([organizationId, entryNumber])
  @@unique([organizationId, sourceType, sourceId])
  @@index([entryDate, status])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  branchId       String
  accountId      String
  lineNumber     Int
  description    String?      @db.VarChar(500)
  debit          Decimal      @default(0) @db.Decimal(18, 4)
  credit         Decimal      @default(0) @db.Decimal(18, 4)
  createdAt      DateTime     @default(now())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  branch         Branch       @relation(fields: [branchId], references: [id])
  account        Account      @relation(fields: [accountId], references: [id])

  @@unique([journalEntryId, lineNumber])
  @@index([branchId, accountId])
}

model DocumentSequence {
  id             String       @id @default(cuid())
  organizationId String
  branchId       String
  documentType   DocumentType
  prefix         String       @db.VarChar(20)
  nextNumber     Int          @default(1)
  padding        Int          @default(6)
  resetYearly    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  branch         Branch       @relation(fields: [branchId], references: [id])

  @@unique([branchId, documentType])
}

model OutboxEvent {
  id            String            @id @default(cuid())
  aggregateType String            @db.VarChar(60)
  aggregateId   String            @db.VarChar(50)
  eventType     String            @db.VarChar(120)
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  attempts      Int               @default(0)
  availableAt   DateTime          @default(now())
  processedAt   DateTime?
  createdAt     DateTime          @default(now())

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
}
